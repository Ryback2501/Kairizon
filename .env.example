# Next.js Auth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=          # openssl rand -base64 32

# Google OAuth (https://console.cloud.google.com)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Database
DATABASE_URL=postgresql://kairizon:kairizon@localhost:5432/kairizon

# Email — Gmail SMTP example
# Use an App Password (not your account password). Requires 2FA on Google account.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=
SMTP_FROM="Kairizon <your@gmail.com>"
