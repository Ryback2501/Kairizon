{
  "name": "kairizon",
  "version": "0.2.0",
  "private": true,
  "scripts": {
    "dev": "ts-node -r tsconfig-paths/register --project tsconfig.server.json server.ts",
    "build": "next build && tsc --project tsconfig.server.json",
    "start": "node dist/server.js",
    "lint": "eslint .",
    "test": "jest",
    "test:unit": "jest --testPathPatterns=tests/unit",
    "test:integration": "jest --testPathPatterns=tests/integration",
    "test:e2e": "playwright test",
    "test:all": "npm run test && npm run test:e2e"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "axios": "^1.7.7",
    "cheerio": "^1.2.0",
    "next": "^15.5.15",
    "node-cron": "^3.0.3",
    "nodemailer": "^8.0.5",
    "playwright": "^1.59.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@playwright/test": "^1.48.2",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.17.6",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^6.4.16",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.39.4",
    "eslint-config-next": "^15.5.15",
    "jest": "^30.3.0",
    "jest-environment-node": "^30.3.0",
    "postcss": "^8.4.47",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.14",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.6.3",
    "wait-on": "^9.0.5"
  }
}
