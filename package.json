{
  "name": "kairizon",
  "version": "0.2.2",
  "private": true,
  "scripts": {
    "dev": "sh -c 'export DATABASE_URL=file:./data/${DATABASE_FILE:-kairizon.db} && npx prisma db push && ts-node -r tsconfig-paths/register --project tsconfig.server.json server.ts'",
    "build": "next build && tsc --project tsconfig.server.json && tsc-alias --project tsconfig.server.json",
    "start": "NODE_ENV=production sh -c 'export DATABASE_URL=file:./data/${DATABASE_FILE:-kairizon.db} && npx prisma db push && node dist/server.js'",
    "lint": "eslint .",
    "test": "jest",
    "test:unit": "jest --testPathPatterns=tests/unit",
    "test:integration": "jest --testPathPatterns=tests/integration --runInBand",
    "test:e2e": "playwright test",
    "test:all": "npm run test && npm run test:e2e"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "axios": "^1.15.2",
    "cheerio": "^1.2.0",
    "next": "^16.2.4",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.5",
    "playwright": "^1.59.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@playwright/test": "^1.48.2",
    "@tailwindcss/postcss": "^4.2.4",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.0",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^10.2.1",
    "eslint-config-next": "^16.2.4",
    "jest": "^30.3.0",
    "jest-environment-node": "^30.3.0",
    "postcss": "^8.5.10",
    "prisma": "^6.19.3",
    "tailwindcss": "^4.2.4",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.16",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^6.0.3",
    "wait-on": "^9.0.5"
  }
}
