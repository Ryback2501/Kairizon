generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model AppSettings {
  id       String @id @default("singleton")
  smtpHost String @default("")
  smtpPort Int    @default(587)
  smtpUser String @default("")
  smtpPass String @default("")
  smtpFrom String @default("")
}

model Product {
  id            String    @id @default(cuid())
  asin          String    @unique
  title         String
  image         String?
  url           String
  currentPrice  Float?
  targetPrice   Float?
  lastChecked   DateTime?
  notified      Boolean   @default(false)
  inStock       Boolean   @default(true)
  trackStock          Boolean   @default(false)
  stockNotified       Boolean   @default(false)
  includeSecondHand   Boolean   @default(true)
  availableSellers    String    @default("[]")
  excludedSellers     String    @default("[]")
  createdAt           DateTime  @default(now())
}
